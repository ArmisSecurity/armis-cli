pipeline {
    agent any

    environment {
        ARMIS_CLIENT_ID = credentials('armis-client-id')
        ARMIS_CLIENT_SECRET = credentials('armis-client-secret')
    }

    stages {
        stage('Install Armis CLI') {
            steps {
                sh '''
                    curl -sSL https://raw.githubusercontent.com/ArmisSecurity/armis-cli/main/scripts/install.sh | bash
                '''
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                    armis-cli scan repo . --format junit --fail-on HIGH,CRITICAL > scan-results.xml
                '''
            }
            post {
                always {
                    junit 'scan-results.xml'
                }
            }
        }
    }

    post {
        failure {
            echo 'Security scan found critical vulnerabilities!'
        }
    }
}
